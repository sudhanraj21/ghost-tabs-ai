{
  "manifest_version": 3,
  "name": "GhostTabs AI",
  "version": "1.0.0",
  "description": "Turn inactive tabs into lightweight ghost tabs. Save memory while keeping visibility. Resume when ready.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "contextMenus",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.svg",
      "32": "assets/icon32.svg",
      "48": "assets/icon48.svg",
      "128": "assets/icon128.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}